{
  "name": "ergo",
  "version": "0.1.0",
  "private": true,
  "description": "Unified Ergo developer tool. Single-port Hono/WS server hosting particle and variable editors as in-process plugins. Default mode: Electron standalone desktop app.",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start":     "npm run build && electron .",
    "app":       "npm run build && electron .",
    "serve":     "tsx src/main.ts",
    "dev":       "tsx watch src/main.ts",
    "build":     "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@hono/node-server":  "^1.13.7",
    "hono":               "^4.6.10",
    "ws":                 "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws":   "^8.5.13",
    "electron":    "^33.0.0",
    "tsx":         "^4.19.2",
    "typescript":  "^5.6.3"
  }
}

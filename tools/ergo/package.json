{
  "name": "ergo",
  "version": "0.1.0",
  "private": true,
  "description": "Unified Ergo developer tool. Single-port Hono/WS server hosting particle, variable (and later inspector) editors as in-process plugins.",
  "type": "module",
  "scripts": {
    "dev":   "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono":              "^4.6.10",
    "ws":                "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws":   "^8.5.13",
    "tsx":         "^4.19.2",
    "typescript":  "^5.6.3"
  }
}

{
  "name": "particle-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based particle effect editor that broadcasts edits over WS to engine clients (e.g. AdventureCube via ergo_particle).",
  "type": "module",
  "scripts": {
    "dev":   "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono":              "^4.6.10",
    "ws":                "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws":   "^8.5.13",
    "tsx":         "^4.19.2",
    "typescript":  "^5.6.3"
  }
}
